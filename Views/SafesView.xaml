<UserControl x:Class="CyberArkManager.Views.SafesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <md:PackIcon Kind="Safe" Width="22" Height="22" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
            <TextBlock Text="Gestión de Safes" FontSize="18" FontWeight="Bold" Foreground="White" Margin="8,0,0,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Safes.Count, StringFormat=' · {0} safes'}" FontSize="12" Foreground="#44446A" Margin="6,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="370"/></Grid.ColumnDefinitions>

            <!-- Left: Safes list -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>

                <!-- Search + load -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding FilterSearch, UpdateSourceTrigger=PropertyChanged}" md:HintAssist.Hint="Buscar safe..." Style="{StaticResource MaterialDesignOutlinedTextBox}" Height="34" Margin="0,0,8,0" FontSize="11"/>
                    <Button Grid.Column="1" Command="{Binding LoadCommand}" Height="34" FontSize="11" Margin="0,0,6,0" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" Style="{StaticResource MaterialDesignRaisedButton}">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text=" Cargar" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Grid.Column="2" Command="{Binding LoadMembersCommand}" Height="34" FontSize="11" Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="AccountGroup" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text=" Miembros" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                </Grid>

                <!-- Safes grid -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,8">
                    <DataGrid ItemsSource="{Binding Safes}" SelectedItem="{Binding SelectedSafe}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              RowBackground="#1A1A2E" AlternatingRowBackground="#16162A"
                              BorderThickness="0" Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nombre"       Binding="{Binding SafeName}"    Width="*"/>
                            <DataGridTextColumn Header="CPM"          Binding="{Binding ManagingCPM}" Width="100"/>
                            <DataGridTextColumn Header="Versiones"    Binding="{Binding NumberOfVersionsRetention}" Width="80"/>
                            <DataGridTextColumn Header="Días"         Binding="{Binding NumberOfDaysRetention}"     Width="60"/>
                            <DataGridCheckBoxColumn Header="OLAC"     Binding="{Binding OlacEnabled}"  Width="50"/>
                            <DataGridCheckBoxColumn Header="AutoPurge" Binding="{Binding AutoPurgeEnabled}" Width="75"/>
                            <DataGridTextColumn Header="Creado"       Binding="{Binding CreationDisplay}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Members -->
                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="MIEMBROS DEL SAFE SELECCIONADO" FontSize="9" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="10,8,0,6"/>
                        <DataGrid ItemsSource="{Binding Members}" SelectedItem="{Binding SelectedMember}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  RowBackground="#1A1A2E" BorderThickness="0" Style="{StaticResource MaterialDesignDataGrid}" FontSize="11">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Miembro"  Binding="{Binding MemberName}"   Width="*"/>
                                <DataGridTextColumn Header="Tipo"     Binding="{Binding MemberType}"   Width="70"/>
                                <DataGridTextColumn Header="Expiración" Binding="{Binding ExpirationDisplay}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Right: Operations panel -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0">
                <TabControl Style="{StaticResource MaterialDesignTabControl}">

                    <!-- Crear/Editar Safe -->
                    <TabItem Header="Safe">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                            <StackPanel>
                                <TextBlock Text="CREAR / EDITAR SAFE" FontSize="9" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>
                                <TextBox Text="{Binding NewName,  UpdateSourceTrigger=PropertyChanged}" md:HintAssist.Hint="Nombre del Safe *"    md:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,8" FontSize="12"/>
                                <TextBox Text="{Binding NewDesc,  UpdateSourceTrigger=PropertyChanged}" md:HintAssist.Hint="Descripción"           md:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,8" FontSize="12"/>
                                <TextBox Text="{Binding NewCpm,   UpdateSourceTrigger=PropertyChanged}" md:HintAssist.Hint="CPM responsable"          md:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,8" FontSize="12"/>
                                <TextBox Text="{Binding NewLoc,   UpdateSourceTrigger=PropertyChanged}" md:HintAssist.Hint="Ubicación (\\Folder)"  md:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,8" FontSize="12"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding NewVersions}" md:HintAssist.Hint="Versiones" md:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,6,0" FontSize="12"/>
                                    <TextBox Grid.Column="1" Text="{Binding NewDays}"     md:HintAssist.Hint="Días retención" md:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="12"/>
                                </Grid>
                                <CheckBox Content="Purgado automático habilitado" IsChecked="{Binding NewAutoPurge}" Foreground="#9999BB" Margin="0,0,0,6" FontSize="11"/>
                                <CheckBox Content="OLAC habilitado"       IsChecked="{Binding NewOlac}"      Foreground="#9999BB" Margin="0,0,0,12" FontSize="11"/>
                                <WrapPanel>
                                    <Button Command="{Binding CreateCommand}" Height="34" FontSize="11" Margin="0,0,6,0" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" Style="{StaticResource MaterialDesignRaisedButton}">
                                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="Plus" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Crear" VerticalAlignment="Center"/></StackPanel>
                                    </Button>
                                    <Button Command="{Binding UpdateCommand}" Height="34" FontSize="11" Margin="0,0,6,0" Style="{StaticResource MaterialDesignOutlinedButton}">
                                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="ContentSave" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Actualizar" VerticalAlignment="Center"/></StackPanel>
                                    </Button>
                                    <Button Command="{Binding DeleteCommand}" Height="34" FontSize="11" Foreground="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBrush}" Style="{StaticResource MaterialDesignOutlinedButton}">
                                        <md:PackIcon Kind="Delete" Width="13" Height="13"/>
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Miembros -->
                    <TabItem Header="Miembros">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                            <StackPanel>
                                <TextBlock Text="AÑADIR MIEMBRO" FontSize="9" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>
                                <TextBox Text="{Binding MemberName, UpdateSourceTrigger=PropertyChanged}" md:HintAssist.Hint="Nombre de usuario/grupo *" md:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,8" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding MemberTypes}" SelectedItem="{Binding MemberType}" md:HintAssist.Hint="Tipo" md:HintAssist.IsFloating="True" Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,0,12" FontSize="12"/>
                                <TextBlock Text="PERMISOS" FontSize="9" Foreground="#44446A" FontWeight="Bold" Margin="0,0,0,6"/>
                                <CheckBox Content="Gestionar Safe y miembros" IsChecked="{Binding PermManage}" Foreground="#9999BB" FontSize="11" Margin="0,0,0,4"/>
                                <CheckBox Content="Listar cuentas"            IsChecked="{Binding PermList}"   Foreground="#9999BB" FontSize="11" Margin="0,0,0,4"/>
                                <CheckBox Content="Añadir cuentas"            IsChecked="{Binding PermAdd}"    Foreground="#9999BB" FontSize="11" Margin="0,0,0,4"/>
                                <CheckBox Content="Eliminar cuentas"          IsChecked="{Binding PermDelete}" Foreground="#9999BB" FontSize="11" Margin="0,0,0,4"/>
                                <CheckBox Content="Usar / recuperar cuentas"   IsChecked="{Binding PermUse}"    Foreground="#9999BB" FontSize="11" Margin="0,0,0,4"/>
                                <CheckBox Content="Ver auditoría y miembros"  IsChecked="{Binding PermView}"   Foreground="#9999BB" FontSize="11" Margin="0,0,0,12"/>
                                <WrapPanel>
                                    <Button Command="{Binding AddMemberCommand}" Height="34" FontSize="11" Margin="0,0,6,0" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" Style="{StaticResource MaterialDesignRaisedButton}">
                                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="AccountPlus" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Añadir" VerticalAlignment="Center"/></StackPanel>
                                    </Button>
                                    <Button Command="{Binding RemoveMemberCommand}" Height="34" FontSize="11" Foreground="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBrush}" Style="{StaticResource MaterialDesignOutlinedButton}">
                                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="AccountMinus" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Quitar seleccionado" VerticalAlignment="Center"/></StackPanel>
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Margin="0,6,0,0" FontSize="11"
                   Foreground="{Binding HasError, Converter={StaticResource BoolToColor}, ConverterParameter='#F44336|#4CAF50'}"
                   Visibility="{Binding StatusMessage, Converter={StaticResource NullToVis}}"/>
    </Grid>
</UserControl>

