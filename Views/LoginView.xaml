<UserControl x:Class="CyberArkManager.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Background="#0B0B16">
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="440"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#0D0D1A">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                <md:PackIcon Kind="ShieldLock" Width="72" Height="72" Foreground="#00BCD4" HorizontalAlignment="Center"/>
                <TextBlock Text="CyberArk Manager" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,14,0,6"/>
                <TextBlock Text="Navaja Suiza PAM v2.0" FontSize="12" Foreground="#44446A" HorizontalAlignment="Center"/>
                <Separator Margin="30,20" Background="#1A1A40"/>
                <TextBlock TextWrapping="Wrap" Foreground="#333355" FontSize="11" TextAlignment="Center">
                    Acceso local y acceso a PVWA para CyberArk PAM&#x0a;API REST / .NET 8 / WPF / DPAPI
                </TextBlock>
            </StackPanel>
        </Border>
        <Border Grid.Column="1" VerticalAlignment="Center" Padding="2">
            <md:Card Padding="38,34" Background="#1A1A2E" UniformCornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Acceso" FontSize="21" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                    <TextBlock Text="Conéctate a CyberArk PVWA o usa el modo local" FontSize="11" Foreground="#44446A" Margin="0,0,0,24"/>

                    <TextBox Text="{Binding PvwaUrl, UpdateSourceTrigger=PropertyChanged}"
                             md:HintAssist.Hint="URL de PVWA (https://pvwa.empresa.com)"
                             md:HintAssist.IsFloating="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             IsEnabled="{Binding RequiresPvwaUrl}"
                             FontFamily="Consolas" FontSize="11" Margin="0,0,0,14"/>

                    <ComboBox ItemsSource="{Binding AuthMethods}"
                              SelectedValue="{Binding SelectedAuthMethod}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="DisplayName"
                              md:HintAssist.Hint="Método de autenticación"
                              md:HintAssist.IsFloating="True"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="0,0,0,14"/>

                    <Border Background="#1200BCD4" CornerRadius="4" Padding="10,8" Margin="0,0,0,14"
                            Visibility="{Binding IsLocalMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="El modo local permite abrir la interfaz, preparar CSV de alta y gestionar plantillas locales sin conexión a PVWA."
                                   TextWrapping="Wrap" FontSize="11" Foreground="#9FE8F2"/>
                    </Border>

                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             md:HintAssist.Hint="Usuario"
                             md:HintAssist.IsFloating="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,14"/>

                    <PasswordBox x:Name="PbPwd"
                                 md:HintAssist.Hint="Contraseña"
                                 md:HintAssist.IsFloating="True"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 IsEnabled="{Binding RequiresCredentials}"
                                 PasswordChanged="Pwd_Changed"
                                 Margin="0,0,0,14"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" Content="Recordar usuario" IsChecked="{Binding RememberUsername}" Foreground="#6666AA" FontSize="11"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Renovación:" Foreground="#44446A" FontSize="10" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding HeartbeatMin}" Width="34" Margin="5,0,2,0" TextAlignment="Center" FontSize="11" Style="{StaticResource MaterialDesignOutlinedTextBox}" Padding="4,2"/>
                            <TextBlock Text="min" Foreground="#44446A" FontSize="10" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="{Binding HasError, Converter={StaticResource BoolToColor}, ConverterParameter='#1AF44336|#1A4CAF50'}"
                            CornerRadius="4" Padding="10,6" Margin="0,4,0,14"
                            Visibility="{Binding StatusMessage, Converter={StaticResource NullToVis}}">
                        <TextBlock Text="{Binding StatusMessage}" FontSize="11" TextWrapping="Wrap"
                                   Foreground="{Binding HasError, Converter={StaticResource BoolToColor}, ConverterParameter='#F44336|#4CAF50'}"/>
                    </Border>

                    <Button Command="{Binding LoginCommand}" Height="42" FontSize="13" FontWeight="Bold" IsDefault="True"
                            Background="#00BCD4" BorderBrush="#00BCD4"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Login" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text=" ENTRAR" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </md:Card>
        </Border>
        <Border Grid.Column="2" Background="#0D0D1A"/>
    </Grid>
</UserControl>

