<UserControl x:Class="CyberArkManager.Views.CsvGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False">
        <Grid Margin="18,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <md:PackIcon Kind="FileDelimited" Width="22" Height="22" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="CSV Builder / Bulk API Upload" FontSize="18" FontWeight="Bold" Foreground="White" Margin="8,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding RowCount, StringFormat=' - {0} rows in current preview'}" FontSize="12" Foreground="#44446A" Margin="6,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12,8" Margin="0,0,0,10"
                    Visibility="{Binding IsLocalMode, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Local mode is active. CSV generation works fully offline. API upload and account linking are disabled until you sign in to PVWA."
                           TextWrapping="Wrap" FontSize="11" Foreground="#9FE8F2"/>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="12,8" Margin="0,0,0,10">
                <WrapPanel>
                    <Button Command="{Binding AddRowCommand}" Height="34" FontSize="11" Margin="0,0,6,0" Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="Plus" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Add Row" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Command="{Binding RemoveRowCommand}" Height="34" FontSize="11" Margin="0,0,6,0" Foreground="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBrush}" Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="Minus" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Remove" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Command="{Binding ClearCommand}" Height="34" FontSize="11" Margin="0,0,6,0" Foreground="#555577" Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="TrashCan" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Clear All" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Command="{Binding ImportCommand}" Height="34" FontSize="11" Margin="0,0,6,0" Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="Upload" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Import CSV/TXT" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Command="{Binding PreviewCommand}" Height="34" FontSize="11" Margin="0,0,6,0" Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="OpenInNew" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Preview Window" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Command="{Binding SaveProcessedCommand}" Height="34" FontSize="11" Margin="0,0,6,0" Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="ContentSaveOutline" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Save Processed" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Command="{Binding ExportCommand}" Height="34" FontSize="11" Margin="0,0,6,0" Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="Download" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Export CSV" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Command="{Binding TemplateCommand}" Height="34" FontSize="11" Margin="0,0,14,0" Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="FileOutline" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Empty CSV" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Command="{Binding UploadApiCommand}" IsEnabled="{Binding CanUploadToApi}" Height="34" FontSize="12" FontWeight="Bold" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" Style="{StaticResource MaterialDesignRaisedButton}">
                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="CloudUpload" Width="15" Height="15" VerticalAlignment="Center"/><TextBlock Text=" Upload by API" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                </WrapPanel>
            </Border>

            <Grid Grid.Row="3" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*"/>
                    <ColumnDefinition Width="0.95*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="12" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Application Template" FontSize="15" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Each imported server expands into one account per template row. The exported CSV uses the official columns username,address,safe,platformID,password,EnableAutoMgmt,ManualMgmtReason."
                                       FontSize="10" Foreground="#6666AA" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,12,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ComboBox Grid.Row="0" Grid.Column="0" ItemsSource="{Binding Templates}" SelectedItem="{Binding SelectedTemplate}" DisplayMemberPath="Name"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,8,8"
                                      md:HintAssist.Hint="Saved template" md:HintAssist.IsFloating="True"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TemplateName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,8,8"
                                     md:HintAssist.Hint="Template name" md:HintAssist.IsFloating="True"/>
                            <ComboBox Grid.Row="0" Grid.Column="2" ItemsSource="{Binding AccountCountOptions}" SelectedItem="{Binding AccountsPerServer}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,0,8"
                                      md:HintAssist.Hint="Accounts/server" md:HintAssist.IsFloating="True"/>

                            <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding TemplateDescription, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,8,0"
                                     md:HintAssist.Hint="Description" md:HintAssist.IsFloating="True"/>
                            <WrapPanel Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right">
                                <Button Command="{Binding SaveTemplateCommand}" Height="32" FontSize="10" Margin="0,0,6,0" Style="{StaticResource MaterialDesignOutlinedButton}">
                                    <StackPanel Orientation="Horizontal"><md:PackIcon Kind="ContentSave" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Save" VerticalAlignment="Center"/></StackPanel>
                                </Button>
                                <Button Command="{Binding LoadTemplateCommand}" Height="32" FontSize="10" Margin="0,0,6,0" Style="{StaticResource MaterialDesignOutlinedButton}">
                                    <StackPanel Orientation="Horizontal"><md:PackIcon Kind="TrayArrowDown" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Load" VerticalAlignment="Center"/></StackPanel>
                                </Button>
                                <Button Command="{Binding DeleteTemplateCommand}" Height="32" FontSize="10" Margin="0,0,6,0" Foreground="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBrush}" Style="{StaticResource MaterialDesignOutlinedButton}">
                                    <StackPanel Orientation="Horizontal"><md:PackIcon Kind="Delete" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Delete" VerticalAlignment="Center"/></StackPanel>
                                </Button>
                                <Button Command="{Binding NewTemplateCommand}" Height="32" FontSize="10" Style="{StaticResource MaterialDesignOutlinedButton}">
                                    <StackPanel Orientation="Horizontal"><md:PackIcon Kind="Pencil" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" New" VerticalAlignment="Center"/></StackPanel>
                                </Button>
                            </WrapPanel>
                        </Grid>

                        <DataGrid Grid.Row="2" Height="300"
                                  ItemsSource="{Binding AccountProfiles}" SelectedItem="{Binding SelectedProfile}"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  EnableRowVirtualization="True" EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  RowBackground="#1A1A2E" AlternatingRowBackground="#16162A"
                                  BorderThickness="0" Style="{StaticResource MaterialDesignDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="42" IsReadOnly="True"/>
                                <DataGridTextColumn Header="safe" Binding="{Binding SafeName, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                                <DataGridTextColumn Header="platformID" Binding="{Binding PlatformId, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                                <DataGridTextColumn Header="username" Binding="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                                <DataGridTextColumn Header="password" Binding="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                                <DataGridCheckBoxColumn Header="EnableAutoMgmt" Binding="{Binding AutoManagement, UpdateSourceTrigger=PropertyChanged}" Width="105"/>
                                <DataGridTextColumn Header="ManualMgmtReason" Binding="{Binding ManualReason, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                <DataGridCheckBoxColumn Header="UseSudoOnReconcile" Binding="{Binding UseSudoOnReconcile, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Server Input" FontSize="15" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Import CSV/TXT from the toolbar or paste one address per line here. The current template is expanded over every imported server."
                                       FontSize="10" Foreground="#6666AA" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>

                        <TextBox Grid.Row="1" Text="{Binding ManualAddressesInput, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap"
                                 Margin="0,12,0,10" MinHeight="150"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 md:HintAssist.Hint="server01&#10;server02.domain.local&#10;10.10.10.10" md:HintAssist.IsFloating="True"/>

                        <WrapPanel Grid.Row="2" Margin="0,0,0,10">
                            <Button Command="{Binding ImportAddressesCommand}" Height="34" FontSize="11" Margin="0,0,6,0" Style="{StaticResource MaterialDesignOutlinedButton}">
                                <StackPanel Orientation="Horizontal"><md:PackIcon Kind="ClipboardText" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Paste Address List" VerticalAlignment="Center"/></StackPanel>
                            </Button>
                            <Button Command="{Binding PreviewCommand}" Height="34" FontSize="11" Margin="0,0,6,0" Style="{StaticResource MaterialDesignOutlinedButton}">
                                <StackPanel Orientation="Horizontal"><md:PackIcon Kind="MonitorEye" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Open Preview" VerticalAlignment="Center"/></StackPanel>
                            </Button>
                            <Button Command="{Binding SaveProcessedCommand}" Height="34" FontSize="11" Style="{StaticResource MaterialDesignOutlinedButton}">
                                <StackPanel Orientation="Horizontal"><md:PackIcon Kind="ArchiveArrowDown" Width="13" Height="13" VerticalAlignment="Center"/><TextBlock Text=" Archive Snapshot" VerticalAlignment="Center"/></StackPanel>
                            </Button>
                        </WrapPanel>

                        <Border Grid.Row="3" Background="#10101C" CornerRadius="6" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Processed CSV Archive" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="{Binding ProcessedCsvDirectory}" FontSize="10" Foreground="#6666AA" TextWrapping="Wrap" Margin="0,4,0,4"/>
                                <TextBlock Text="{Binding LastProcessedCsvPath}" FontSize="10" Foreground="#9FE8F2" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                <WrapPanel Margin="0,0,0,8">
                                    <Button Command="{Binding LoadProcessedCommand}" Height="30" FontSize="10" Margin="0,0,6,0" Style="{StaticResource MaterialDesignOutlinedButton}">
                                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="TrayArrowDown" Width="12" Height="12" VerticalAlignment="Center"/><TextBlock Text=" Load Snapshot" VerticalAlignment="Center"/></StackPanel>
                                    </Button>
                                    <Button Command="{Binding ExportProcessedCommand}" Height="30" FontSize="10" Style="{StaticResource MaterialDesignOutlinedButton}">
                                        <StackPanel Orientation="Horizontal"><md:PackIcon Kind="Download" Width="12" Height="12" VerticalAlignment="Center"/><TextBlock Text=" Export Snapshot" VerticalAlignment="Center"/></StackPanel>
                                    </Button>
                                </WrapPanel>
                                <ListBox ItemsSource="{Binding ProcessedCsvFiles}" SelectedItem="{Binding SelectedProcessedCsv}" Background="Transparent" BorderThickness="0" Height="120" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,6">
                                                <TextBlock Text="{Binding Label}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                <TextBlock Foreground="#6666AA" FontSize="10">
                                                    <Run Text="{Binding CreatedAtDisplay, Mode=OneWay}"/>
                                                    <Run Text=" - "/>
                                                    <Run Text="{Binding Reason, Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding StorageDisplay, Mode=OneWay}" Foreground="#9FE8F2" FontSize="10"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="4" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Preview" FontSize="15" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Scrollable preview of the final CSV. Exported headers are username,address,safe,platformID,password,EnableAutoMgmt,ManualMgmtReason and UseSudoOnReconcile only when enabled."
                                   FontSize="10" Foreground="#6666AA" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" Height="420"
                              ItemsSource="{Binding Rows}" SelectedItem="{Binding SelectedRow}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              EnableRowVirtualization="True" EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              RowBackground="#1A1A2E" AlternatingRowBackground="#16162A"
                              BorderThickness="0" Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="48" IsReadOnly="True"/>
                            <DataGridTextColumn Header="username" Binding="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                            <DataGridTextColumn Header="address" Binding="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                            <DataGridTextColumn Header="safe" Binding="{Binding SafeName, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                            <DataGridTextColumn Header="platformID" Binding="{Binding PlatformId, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                            <DataGridTextColumn Header="password" Binding="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                            <DataGridCheckBoxColumn Header="EnableAutoMgmt" Binding="{Binding AutoManagement, UpdateSourceTrigger=PropertyChanged}" Width="115"/>
                            <DataGridTextColumn Header="ManualMgmtReason" Binding="{Binding ManualReason, UpdateSourceTrigger=PropertyChanged}" Width="170"/>
                            <DataGridCheckBoxColumn Header="UseSudoOnReconcile" Binding="{Binding UseSudoOnReconcile, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                            <DataGridTextColumn Header="status" Binding="{Binding StatusText}" Width="90" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding StatusColor}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="5" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="0.9*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="API Account Linking" FontSize="15" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Provide one or more server addresses plus the shared account name. The app finds that logon or reconciliation account on each server and links it to the other accounts for the same address."
                                       FontSize="10" Foreground="#6666AA" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,12,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding LinkedAccountName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,8,0"
                                     md:HintAssist.Hint="Shared linked account name" md:HintAssist.IsFloating="True"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding LinkTypeOptions}" SelectedItem="{Binding SelectedLinkTypeOption}" DisplayMemberPath="DisplayName"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      md:HintAssist.Hint="Link type" md:HintAssist.IsFloating="True"/>
                        </Grid>

                        <TextBox Grid.Row="2" Text="{Binding LinkAddressesInput, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap"
                                 MinHeight="150"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 md:HintAssist.Hint="srv-app-01&#10;srv-app-02&#10;10.10.10.10" md:HintAssist.IsFloating="True"/>
                    </Grid>

                    <Border Grid.Column="1" Background="#10101C" CornerRadius="6" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="120"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Link execution" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                            <Button Grid.Row="1" Command="{Binding LinkAccountsCommand}" IsEnabled="{Binding CanUseApiOperations}"
                                    Height="34" Margin="0,10,0,8"
                                    Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}"
                                    Style="{StaticResource MaterialDesignRaisedButton}">
                                <StackPanel Orientation="Horizontal"><md:PackIcon Kind="LinkVariant" Width="14" Height="14" VerticalAlignment="Center"/><TextBlock Text=" Link Matching Accounts" VerticalAlignment="Center"/></StackPanel>
                            </Button>
                            <StackPanel Grid.Row="2" Margin="0,0,0,8">
                                <ProgressBar Height="6" Minimum="0" Maximum="100" Value="{Binding LinkProgress}" Foreground="{StaticResource AccentBrush}"
                                             Visibility="{Binding IsLinkingAccounts, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="{Binding LinkStatusMessage}" FontSize="10" Foreground="#9FE8F2" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            </StackPanel>
                            <ListBox Grid.Row="3" ItemsSource="{Binding LinkLog}" Background="Transparent" BorderThickness="0" FontFamily="Consolas" FontSize="10" Foreground="#9999BB" ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="6" Style="{StaticResource Card}" Padding="14,10" Margin="0,0,0,0"
                    Visibility="{Binding IsUploading, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="100"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,6">
                        <Run Text="Uploading... "/>
                        <Run Text="{Binding UploadOk}" Foreground="#4CAF50"/>
                        <Run Text=" OK  "/>
                        <Run Text="{Binding UploadFail}" Foreground="#F44336"/>
                        <Run Text=" errors"/>
                    </TextBlock>
                    <ProgressBar Grid.Row="1" Value="{Binding UploadProgress}" Minimum="0" Maximum="100" Height="6" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                    <ListBox Grid.Row="2" ItemsSource="{Binding Log}" Background="Transparent" BorderThickness="0" FontFamily="Consolas" FontSize="10" Foreground="#9999BB" ScrollViewer.HorizontalScrollBarVisibility="Disabled" VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0,1"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <TextBlock Grid.Row="7" Text="{Binding StatusMessage}" Margin="0,6,0,0" FontSize="11"
                       Foreground="{Binding HasError, Converter={StaticResource BoolToColor}, ConverterParameter='#F44336|#4CAF50'}"
                       Visibility="{Binding StatusMessage, Converter={StaticResource NullToVis}}"/>
        </Grid>
    </ScrollViewer>
</UserControl>
