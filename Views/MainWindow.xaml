<Window x:Class="CyberArkManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:v="clr-namespace:CyberArkManager.Views"
        xmlns:vm="clr-namespace:CyberArkManager.ViewModels"
        Title="CyberArk Manager v2 â€” Navaja Suiza PAM"
        Height="800" Width="1300" MinHeight="650" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ContentBg}"
        Style="{StaticResource MaterialDesignWindow}"
        FontFamily="{md:MaterialDesignFont}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:AccountsViewModel}">
            <v:AccountsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SafesViewModel}">
            <v:SafesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}">
            <v:UsersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PlatformsViewModel}">
            <v:PlatformsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PsmSessionsViewModel}">
            <v:PsmSessionsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PsmRecordingsViewModel}">
            <v:PsmRecordingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ApplicationsViewModel}">
            <v:ApplicationsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DiscoveredAccountsViewModel}">
            <v:DiscoveredAccountsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SystemHealthViewModel}">
            <v:SystemHealthView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AccessRequestsViewModel}">
            <v:AccessRequestsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CsvGeneratorViewModel}">
            <v:CsvGeneratorView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid Visibility="{Binding IsLoginView, Converter={StaticResource BoolToVis}}">
            <v:LoginView DataContext="{Binding LoginVM}"/>
        </Grid>

        <Grid Visibility="{Binding IsMainView, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="14,18,14,8">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ShieldLock" Width="26" Height="26" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="CyberArk" FontSize="17" FontWeight="Bold" Foreground="White" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="PAM Manager v2.0" FontSize="10" Foreground="#44446A" Margin="34,2,0,0"/>
                        <Separator Margin="0,12,0,0" Background="#1A1A40"/>
                    </StackPanel>

                    <Border DockPanel.Dock="Bottom" Background="#0A0A18" Padding="12,10">
                        <StackPanel>
                            <Separator Background="#1A1A40" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <md:PackIcon Kind="AccountCircle" Foreground="{StaticResource AccentBrush}" Width="15" Height="15" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentUser}" Foreground="White" FontWeight="SemiBold" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="10" Foreground="#44446A" Margin="2,0,0,2">
                                <Run Text="â± SesiÃ³n:"/> <Run Text="{Binding SessionTime}" Foreground="#7777AA"/>
                            </TextBlock>
                            <TextBlock FontSize="10" Foreground="#44446A" Margin="2,0,0,6">
                                <Run Text="ðŸ”„ Renovado:"/> <Run Text="{Binding LastRenewTime}" Foreground="#7777AA"/>
                            </TextBlock>
                            <Button Command="{Binding LogoffCommand}" Height="30" FontSize="11"
                                    Foreground="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBrush}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Logout" Width="13" Height="13" VerticalAlignment="Center"/>
                                    <TextBlock Text=" Cerrar SesiÃ³n" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding ClockTime}" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}" Margin="16,4,0,8" FontFamily="Consolas"/>

                            <TextBlock Text="CUENTAS" Style="{StaticResource SectionLabel}"/>
                            <Button Command="{Binding NavCommand}" CommandParameter="Accounts" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="AccountKey" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="  GestiÃ³n de Cuentas" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="SAFES" Style="{StaticResource SectionLabel}"/>
                            <Button Command="{Binding NavCommand}" CommandParameter="Safes" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Safe" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="  GestiÃ³n de Safes" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="IDENTIDADES" Style="{StaticResource SectionLabel}"/>
                            <Button Command="{Binding NavCommand}" CommandParameter="Users" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="AccountGroup" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="  Usuarios y Grupos" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding NavCommand}" CommandParameter="Applications" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Application" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="  Aplicaciones" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="CONFIGURACIÃ“N" Style="{StaticResource SectionLabel}"/>
                            <Button Command="{Binding NavCommand}" CommandParameter="Platforms" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Cog" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="  Plataformas" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="SESIONES PSM" Style="{StaticResource SectionLabel}"/>
                            <Button Command="{Binding NavCommand}" CommandParameter="PsmSessions" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="DesktopClassic" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="  Sesiones Activas" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding NavCommand}" CommandParameter="PsmRecordings" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="RecordCircle" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="  Grabaciones" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="DESCUBRIMIENTO" Style="{StaticResource SectionLabel}"/>
                            <Button Command="{Binding NavCommand}" CommandParameter="DiscoveredAccounts" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Magnify" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="  Cuentas Descubiertas" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding NavCommand}" CommandParameter="AccessRequests" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="ClipboardCheck" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="  Solicitudes Acceso" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="MONITORIZACIÃ“N" Style="{StaticResource SectionLabel}"/>
                            <Button Command="{Binding NavCommand}" CommandParameter="SystemHealth" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="HeartPulse" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="  Salud del Sistema" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="UTILIDADES" Style="{StaticResource SectionLabel}"/>
                            <Button Command="{Binding NavCommand}" CommandParameter="CsvGenerator" Style="{StaticResource NavBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="FileDelimited" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="  Generador CSV / API" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ContentControl Grid.Row="0" Content="{Binding CurrentContentViewModel}"/>

                <Border Grid.Row="1" Background="#0A0A18" BorderBrush="#1A1A40" BorderThickness="0,1,0,0" Padding="14,5">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Style="{StaticResource StatusTxt}"
                                   Foreground="{Binding HasError, Converter={StaticResource BoolToColor}, ConverterParameter='#F44336|#6666AA'}"/>
                        <TextBlock Grid.Column="1" Text="CyberArk Manager v2.0 Â· .NET 8" Style="{StaticResource StatusTxt}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Background="#AA000010" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" Width="44" Height="44" IsIndeterminate="True" Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="Procesando..." Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
