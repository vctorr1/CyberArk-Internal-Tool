<Application x:Class="CyberArkManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- MaterialDesign Dark Theme -->
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="Teal"
                                             SecondaryColor="Amber" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- App-level colors -->
            <Color x:Key="SidebarBg">#1A1A2E</Color>
            <Color x:Key="SidebarSelected">#16213E</Color>
            <Color x:Key="AccentTeal">#00BCD4</Color>
            <Color x:Key="DangerRed">#F44336</Color>
            <Color x:Key="SuccessGreen">#4CAF50</Color>

            <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarBg}" />
            <SolidColorBrush x:Key="SidebarSelectedBrush" Color="{StaticResource SidebarSelected}" />
            <SolidColorBrush x:Key="AccentTealBrush" Color="{StaticResource AccentTeal}" />
            <SolidColorBrush x:Key="DangerRedBrush" Color="{StaticResource DangerRed}" />
            <SolidColorBrush x:Key="SuccessGreenBrush" Color="{StaticResource SuccessGreen}" />

            <!-- Sidebar nav button style -->
            <Style x:Key="SideNavButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="Foreground" Value="#BBBBCC" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="Height" Value="48" />
                <Setter Property="Margin" Value="0,2" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="16,0" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Background" Value="#22FFFFFF" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Active nav button style -->
            <Style x:Key="SideNavButtonActive" TargetType="Button" BasedOn="{StaticResource SideNavButton}">
                <Setter Property="Foreground" Value="{StaticResource AccentTealBrush}" />
                <Setter Property="Background" Value="#1A00BCD4" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <!-- Status bar text -->
            <Style x:Key="StatusText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="#AAAAAA" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
