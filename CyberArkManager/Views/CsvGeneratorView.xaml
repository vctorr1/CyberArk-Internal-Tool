<UserControl x:Class="CyberArkManager.Views.CsvGeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:services="clr-namespace:CyberArkManager.Services">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="FileDelimited" Width="24" Height="24"
                                         Foreground="{StaticResource AccentTealBrush}"
                                         VerticalAlignment="Center" />
                <TextBlock Text="Generador de Plantillas CSV"
                           FontSize="20" FontWeight="Bold" Foreground="White"
                           Margin="10,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="Crea cuentas en formato Bulk Load de CyberArk o súbelas directamente via API"
                       Foreground="#666688" FontSize="12" Margin="34,2,0,0" />
        </StackPanel>

        <!-- DataGrid -->
        <Border Grid.Row="1" CornerRadius="6"
                Background="#1A1A2E"
                BorderBrush="#222244" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Rows}"
                      SelectedItem="{Binding SelectedRow}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowBackground="#1E1E30"
                      AlternatingRowBackground="#1A1A2A"
                      BorderThickness="0"
                      Margin="1"
                      Style="{StaticResource MaterialDesignDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Safe Name"      Binding="{Binding SafeName}"    Width="150" />
                    <DataGridTextColumn Header="Platform ID"    Binding="{Binding PlatformId}"  Width="130" />
                    <DataGridTextColumn Header="Address"        Binding="{Binding Address}"     Width="160" />
                    <DataGridTextColumn Header="User Name"      Binding="{Binding UserName}"    Width="130" />
                    <DataGridTextColumn Header="Password"       Binding="{Binding Password}"    Width="100" />
                    <DataGridTextColumn Header="Descripción"    Binding="{Binding Description}" Width="140" />
                    <DataGridCheckBoxColumn Header="Auto CPM"   Binding="{Binding AutomaticManagement}" Width="75" />
                    <DataGridTextColumn Header="Estado"         Binding="{Binding StatusDisplay}" Width="90" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding StatusColor}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Action Buttons Row -->
        <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Command="{Binding AddRowCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,8" Height="36" FontSize="11">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plus" Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text=" Añadir Fila" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding RemoveRowCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,8" Height="36" FontSize="11"
                    Foreground="{StaticResource DangerRedBrush}"
                    BorderBrush="{StaticResource DangerRedBrush}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Minus" Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text=" Quitar Fila" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                       Margin="4,0,12,8" />

            <Button Command="{Binding ImportCsvCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,8" Height="36" FontSize="11">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Upload" Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text=" Importar CSV" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding ExportCsvCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,8" Height="36" FontSize="11">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Download" Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text=" Exportar CSV" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding ExportTemplateCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,8" Height="36" FontSize="11">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileOutline" Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text=" Plantilla Vacía" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                       Margin="4,0,12,8" />

            <!-- Main action: Direct API upload -->
            <Button Command="{Binding BulkUploadCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{StaticResource AccentTealBrush}"
                    BorderBrush="{StaticResource AccentTealBrush}"
                    Margin="0,0,8,8" Height="36" FontSize="11" FontWeight="Bold">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CloudUpload" Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text=" Subida Directa API" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding ClearAllCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="#555577"
                    Margin="0,0,0,8" Height="36" FontSize="11">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="TrashCan" Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text=" Limpiar Todo" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </WrapPanel>

        <!-- Upload Progress + Log -->
        <Border Grid.Row="3"
                Visibility="{Binding IsUploading, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="#1A1A2E" CornerRadius="6"
                BorderBrush="#222244" BorderThickness="1"
                Padding="14,10" Margin="0,8,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>

                <!-- Progress stats -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Foreground="White" FontSize="12" FontWeight="SemiBold">
                        <Run Text="Subiendo cuentas… " />
                        <Run Text="{Binding UploadSucceeded}" Foreground="{StaticResource SuccessGreenBrush}" />
                        <Run Text=" OK  " />
                        <Run Text="{Binding UploadFailed}" Foreground="{StaticResource DangerRedBrush}" />
                        <Run Text=" Errores" />
                    </TextBlock>
                </Grid>

                <!-- Progress bar -->
                <ProgressBar Grid.Row="1"
                             Value="{Binding UploadProgress}"
                             Minimum="0" Maximum="100"
                             Height="6"
                             Foreground="{StaticResource AccentTealBrush}"
                             Margin="0,0,0,8" />

                <!-- Log -->
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding UploadLog}"
                         Background="Transparent"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="10"
                         Foreground="#AAAACC"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.ScrollUnit="Pixel">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0,1" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <!-- Status -->
        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Visibility="{Binding IsUploading, Converter={StaticResource InverseBoolToVisConverter}}"
                   Foreground="{Binding HasError, Converter={StaticResource BooleanToObjectConverter},
                               ConverterParameter='#F44336|#4CAF50'}"
                   FontSize="11" Margin="0,8,0,0" />
    </Grid>
</UserControl>
