<UserControl x:Class="CyberArkManager.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Background="#0F0F1A">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Decorative left panel -->
        <Border Grid.Column="0"
                Background="#13131F">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                <materialDesign:PackIcon Kind="ShieldLock"
                                         Width="80" Height="80"
                                         Foreground="#00BCD4"
                                         HorizontalAlignment="Center" />
                <TextBlock Text="CyberArk Manager"
                           FontSize="26" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,8" />
                <TextBlock Text="Navaja Suiza PAM"
                           FontSize="13"
                           Foreground="#555577"
                           HorizontalAlignment="Center" />
                <Separator Margin="40,20" Background="#222244" />
                <TextBlock TextWrapping="Wrap"
                           Foreground="#444466"
                           FontSize="11"
                           TextAlignment="Center">
                    Gestión centralizada de cuentas privilegiadas&#x0a;vía CyberArk REST API v2
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Login Card -->
        <Border Grid.Column="1"
                Background="#1A1A2E"
                VerticalAlignment="Center">
            <materialDesign:Card Padding="40,36"
                                 Background="#1E1E30"
                                 UniformCornerRadius="8">
                <StackPanel>
                    <!-- Header -->
                    <TextBlock Text="Iniciar Sesión"
                               FontSize="22" FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Conectar con CyberArk PVWA"
                               FontSize="12"
                               Foreground="#666688"
                               Margin="0,0,0,28" />

                    <!-- PVWA URL -->
                    <TextBox x:Name="TxtPvwaUrl"
                             Text="{Binding PvwaUrl, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="URL del PVWA (ej: https://pvwa.empresa.com)"
                             materialDesign:HintAssist.IsFloating="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,16"
                             FontFamily="Consolas"
                             FontSize="12" />

                    <!-- Username -->
                    <TextBox x:Name="TxtUsername"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Usuario"
                             materialDesign:HintAssist.IsFloating="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,16" />

                    <!-- Password -->
                    <PasswordBox x:Name="PbPassword"
                                 materialDesign:HintAssist.Hint="Contraseña"
                                 materialDesign:HintAssist.IsFloating="True"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 Margin="0,0,0,16"
                                 PasswordChanged="PbPassword_PasswordChanged" />

                    <!-- Options row -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  Content="Recordar usuario"
                                  IsChecked="{Binding RememberUsername}"
                                  Foreground="#888899"
                                  FontSize="11" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Keep-alive:" Foreground="#555577" FontSize="10" VerticalAlignment="Center" />
                            <TextBox Text="{Binding HeartbeatInterval, UpdateSourceTrigger=PropertyChanged}"
                                     Width="36" Margin="6,0,2,0"
                                     TextAlignment="Center"
                                     FontSize="11"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Padding="4,2" />
                            <TextBlock Text="min" Foreground="#555577" FontSize="10" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <!-- Status message -->
                    <Border Background="{Binding HasError, Converter={StaticResource BooleanToObjectConverter},
                                         ConverterParameter='#1AF44336|#1A4CAF50'}"
                            CornerRadius="4"
                            Padding="10,6"
                            Margin="0,0,0,16"
                            Visibility="{Binding StatusMessage, Converter={StaticResource NullableToVisibilityConverter}}">
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{Binding HasError, Converter={StaticResource BooleanToObjectConverter},
                                               ConverterParameter='#F44336|#4CAF50'}" />
                    </Border>

                    <!-- Login Button -->
                    <Button Content="CONECTAR"
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Height="44"
                            FontSize="13"
                            FontWeight="Bold"
                            Background="{StaticResource AccentTealBrush}"
                            BorderBrush="{StaticResource AccentTealBrush}"
                            IsDefault="True">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Login" Width="16" Height="16" VerticalAlignment="Center" />
                                    <TextBlock Text=" CONECTAR" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>
            </materialDesign:Card>
        </Border>

        <!-- Empty right column -->
        <Border Grid.Column="2" Background="#13131F" />
    </Grid>
</UserControl>
