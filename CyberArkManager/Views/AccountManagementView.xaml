<UserControl x:Class="CyberArkManager.Views.AccountManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Header -->
            <RowDefinition Height="Auto" />  <!-- Filters -->
            <RowDefinition Height="*"    />  <!-- Table -->
            <RowDefinition Height="Auto" />  <!-- Edit panel -->
            <RowDefinition Height="Auto" />  <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="AccountKey" Width="24" Height="24"
                                         Foreground="{StaticResource AccentTealBrush}"
                                         VerticalAlignment="Center" />
                <TextBlock Text="Gestión de Cuentas"
                           FontSize="20" FontWeight="Bold" Foreground="White"
                           Margin="10,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="Visualiza, edita, rota y elimina cuentas privilegiadas vía API"
                       Foreground="#666688" FontSize="12" Margin="34,2,0,0" />
        </StackPanel>

        <!-- ── Filters ────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="#1A1A2E" CornerRadius="6"
                BorderBrush="#222244" BorderThickness="1"
                Padding="14,10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding FilterSafe, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Filtrar por Safe"
                         materialDesign:HintAssist.IsFloating="False"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,10,0" Height="36" Padding="8,0"
                         FontSize="12" />

                <TextBox Grid.Column="1"
                         Text="{Binding FilterKeyword, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Buscar cuenta / usuario / dirección"
                         materialDesign:HintAssist.IsFloating="False"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,10,0" Height="36" Padding="8,0"
                         FontSize="12" />

                <Button Grid.Column="2"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource AccentTealBrush}"
                        BorderBrush="{StaticResource AccentTealBrush}"
                        Height="36" Margin="0,0,8,0" FontSize="11">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Magnify" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text=" Buscar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3"
                        Command="{Binding ClearFilterCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="36" FontSize="11">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilterRemove" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text=" Limpiar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ── Accounts DataGrid ──────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="#1A1A2E" CornerRadius="6"
                BorderBrush="#222244" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Accounts}"
                      SelectedItem="{Binding SelectedAccount}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowBackground="#1E1E30"
                      AlternatingRowBackground="#1A1A2A"
                      BorderThickness="0"
                      Style="{StaticResource MaterialDesignDataGrid}"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"          Binding="{Binding Id}"                   Width="80"  />
                    <DataGridTextColumn Header="Usuario"     Binding="{Binding UserName}"             Width="140" />
                    <DataGridTextColumn Header="Dirección"   Binding="{Binding Address}"              Width="160" />
                    <DataGridTextColumn Header="Safe"        Binding="{Binding SafeName}"             Width="140" />
                    <DataGridTextColumn Header="Plataforma"  Binding="{Binding PlatformId}"           Width="120" />
                    <DataGridTextColumn Header="Estado CPM"  Binding="{Binding PasswordStatusDisplay}" Width="110" />
                    <DataGridTextColumn Header="Creado"      Binding="{Binding CreatedTimeDisplay}"   Width="130" />
                    <DataGridTextColumn Header="Modificado"  Binding="{Binding LastModifiedDisplay}"  Width="130" />
                </DataGrid.Columns>

                <!-- Row tooltip -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                        <Setter Property="ToolTip" Value="{Binding Name}" />
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Border>

        <!-- ── Edit Panel (shown when row selected) ───────────────────── -->
        <Border Grid.Row="3"
                Background="#1A1A2E" CornerRadius="6"
                BorderBrush="#222244" BorderThickness="1"
                Padding="14,12" Margin="0,10,0,0"
                Visibility="{Binding SelectedAccount, Converter={StaticResource NullableToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.ColumnSpan="4"
                           Text="EDITAR CUENTA SELECCIONADA"
                           FontSize="9" FontWeight="Bold"
                           Foreground="#555577"
                           Margin="0,0,0,8" />

                <!-- These are below the label so we shift via RowDefinitions -->
            </Grid>
        </Border>

        <!-- Edit fields — separate grid for clean layout -->
        <Border Grid.Row="3"
                Background="#1A1A2E" CornerRadius="6"
                BorderBrush="{StaticResource AccentTealBrush}" BorderThickness="1"
                Padding="14,12" Margin="0,10,0,0"
                Visibility="{Binding SelectedAccount, Converter={StaticResource NullableToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="EDITAR CUENTA SELECCIONADA"
                           FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource AccentTealBrush}"
                           Margin="0,0,0,10" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding EditAddress, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Address"
                             materialDesign:HintAssist.IsFloating="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,10,0" FontSize="12" />

                    <TextBox Grid.Column="1"
                             Text="{Binding EditUserName, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="User Name"
                             materialDesign:HintAssist.IsFloating="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,10,0" FontSize="12" />

                    <TextBox Grid.Column="2"
                             Text="{Binding EditPlatformId, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Platform ID"
                             materialDesign:HintAssist.IsFloating="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,10,0" FontSize="12" />

                    <Button Grid.Column="3"
                            Command="{Binding EditAccountCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#1565C0" BorderBrush="#1565C0"
                            Height="40" FontSize="11">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text=" Guardar (PATCH)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Action Buttons ─────────────────────────────────────────── -->
        <WrapPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Command="{Binding LoadAccountsCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{StaticResource AccentTealBrush}"
                    BorderBrush="{StaticResource AccentTealBrush}"
                    Margin="0,0,8,0" Height="36" FontSize="11">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text=" Cargar / Refrescar" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding RotatePasswordCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,0" Height="36" FontSize="11">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="KeyChange" Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text=" Rotar Password" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding VerifyPasswordCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,0" Height="36" FontSize="11">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ShieldCheck" Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text=" Verificar" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding ReconcilePasswordCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,8,0" Height="36" FontSize="11">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="SyncAlert" Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text=" Reconciliar" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding DeleteAccountCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Foreground="{StaticResource DangerRedBrush}"
                    BorderBrush="{StaticResource DangerRedBrush}"
                    Height="36" FontSize="11">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Delete" Width="14" Height="14" VerticalAlignment="Center"/>
                    <TextBlock Text=" Eliminar" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Status -->
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{Binding HasError, Converter={StaticResource BooleanToObjectConverter},
                                   ConverterParameter='#F44336|#4CAF50'}"
                       FontSize="11" Margin="16,0,0,0" VerticalAlignment="Center" />
        </WrapPanel>
    </Grid>
</UserControl>
