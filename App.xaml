<Application x:Class="CyberArkManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:h="clr-namespace:CyberArkManager.Helpers">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="Teal" SecondaryColor="Amber"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <h:BoolToVisConverter  x:Key="BoolToVis"/>
            <h:BoolToVisConverter  x:Key="InvBoolToVis" Invert="True"/>
            <h:NullToVisConverter  x:Key="NullToVis"/>
            <h:BoolToStringConverter x:Key="BoolToStr"/>
            <h:BoolToColorConverter  x:Key="BoolToColor"/>
            <BooleanToVisibilityConverter x:Key="BTV"/>

            <!-- Colors -->
            <SolidColorBrush x:Key="SidebarBg"   Color="#0D0D1A"/>
            <SolidColorBrush x:Key="SidebarHover" Color="#1A1A30"/>
            <SolidColorBrush x:Key="AccentBrush"  Color="#00BCD4"/>
            <SolidColorBrush x:Key="DangerBrush"  Color="#F44336"/>
            <SolidColorBrush x:Key="SuccessBrush" Color="#4CAF50"/>
            <SolidColorBrush x:Key="WarnBrush"    Color="#FF9800"/>
            <SolidColorBrush x:Key="ContentBg"    Color="#12121E"/>
            <SolidColorBrush x:Key="CardBg"       Color="#1A1A2E"/>
            <SolidColorBrush x:Key="BorderBrush_"  Color="#252540"/>

            <!-- Sidebar nav button -->
            <Style x:Key="NavBtn" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                <Setter Property="Foreground" Value="#9999BB"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Height" Value="44"/>
                <Setter Property="Padding" Value="14,0"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Margin" Value="6,1"/>
            </Style>
            <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
                <Setter Property="Foreground" Value="#00BCD4"/>
                <Setter Property="Background" Value="#1800BCD4"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <!-- Section label -->
            <Style x:Key="SectionLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="9"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="#44446A"/>
                <Setter Property="Margin" Value="14,10,0,2"/>
            </Style>

            <!-- Card border -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource CardBg}"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush_}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <!-- Status bar text -->
            <Style x:Key="StatusTxt" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="#6666AA"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
